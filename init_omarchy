#!/usr/bin/env bash
set -e

# Update system
sudo pacman -Syu --noconfirm

# Install base tools
sudo pacman -S --noconfirm \
  curl \
  stow \
  tmux \
  zsh \
  tree \
  broot \
  bat \
  glow

yay -S --noconfirm duckdb-bin

# Install gazelle-tui for eduroam/enterprise WiFi support
yay -S --noconfirm gazelle-tui

# Optional: remove bash dotfiles (safe but not required)
rm -f ~/.bashrc ~/.bash_aliases ~/.vimrc ~/.zshrc

# Stow dotfiles (run from dotfiles repo root)
stow -t ~ bash
stow -t ~ vim
stow -t ~ tmux
stow -t ~ zsh
stow -t ~ git
stow -t ~ bin
stow -t ~ hypr
stow -t ~ waybar
stow -t ~ omarchy

# Hook custom bindings into stock bindings.conf (overrides file lives in dotfiles/hypr).
# Refresh of bindings.conf will drop this line — re-run this block after omarchy update if needed.
if ! grep -qF "source = ~/.config/hypr/bindings-overrides.conf" ~/.config/hypr/bindings.conf; then
    echo "" >> ~/.config/hypr/bindings.conf
    echo "# Custom overrides (kept in dotfiles/hypr/.config/hypr/bindings-overrides.conf)" >> ~/.config/hypr/bindings.conf
    echo "source = ~/.config/hypr/bindings-overrides.conf" >> ~/.config/hypr/bindings.conf
fi

"$HOME/dotfiles/sync_backgrounds"

# Set zsh as default shell
chsh -s /usr/bin/zsh
