#!/bin/bash
# Wrapper around omarchy-capture-screenshot that sorts shots into YYYY-MM subfolders.
# Bound via ~/.config/hypr/bindings-overrides.conf so omarchy migrations cannot reset it.

[[ -f ~/.config/user-dirs.dirs ]] && source ~/.config/user-dirs.dirs
BASE="${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots"
export OMARCHY_SCREENSHOT_DIR="$BASE/$(date +%Y-%m)"
mkdir -p "$OMARCHY_SCREENSHOT_DIR"

exec omarchy-capture-screenshot "$@"
